--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

--// REMOTES
local L_1_ = ReplicatedStorage[player.UserId .. "Client"].StartMove
local L_2_ = ReplicatedStorage[player.UserId .. "Client"].EndMove
local SpinRemote = ReplicatedStorage:WaitForChild("Client"):WaitForChild("Spin")

--// STATE
local farmEXP = false
local autoSpin = false
local spinning = false
local moves = {}


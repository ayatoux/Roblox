--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

--// VARIABLES
local autoFarm = false
local autoSpin = false
local autoIntro = false

local moves = {}

--// REMOTES
local clientFolder = ReplicatedStorage:WaitForChild(player.UserId .. "Client")
local StartMove = clientFolder:WaitForChild("StartMove")
local EndMove = clientFolder:WaitForChild("EndMove")

local SpinRemote = ReplicatedStorage:WaitForChild("Client"):WaitForChild("Spin")
local IntroRemote = ReplicatedStorage:WaitForChild("Client"):WaitForChild("Intro")
local GetSpinsRemote = ReplicatedStorage:WaitForChild("Client"):WaitForChild("GetSpins")

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "MobileGUI"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 200, 0, 250)
frame.Position = UDim2.new(0.1, 0, 0.2, 0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true

local function createButton(text, y)
	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(1, -10, 0, 35)
	btn.Position = UDim2.new(0, 5, 0, y)
	btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Text = text
	return btn
end

local levelLabel = Instance.new("TextLabel", frame)
levelLabel.Size = UDim2.new(1, -10, 0, 25)
levelLabel.Position = UDim2.new(0, 5, 0, 5)
levelLabel.TextColor3 = Color3.new(1,1,1)
levelLabel.BackgroundTransparency = 1
levelLabel.Text = "Level: ?"

local spinLabel = Instance.new("TextLabel", frame)
spinLabel.Size = UDim2.new(1, -10, 0, 25)
spinLabel.Position = UDim2.new(0, 5, 0, 30)
spinLabel.TextColor3 = Color3.new(1,1,1)
spinLabel.BackgroundTransparency = 1
spinLabel.Text = "Spin: ?"

local farmBtn = createButton("Auto Farm: OFF", 60)
local spinBtn = createButton("Auto Spin: OFF", 100)
local introBtn = createButton("Skip Intro: OFF", 140)

--// BUTTON EVENTS
farmBtn.MouseButton1Click:Connect(function()
	autoFarm = not autoFarm
	farmBtn.Text = "Auto Farm: " .. (autoFarm and "ON" or "OFF")
end)

spinBtn.MouseButton1Click:Connect(function()
	autoSpin = not autoSpin
	spinBtn.Text = "Auto Spin: " .. (autoSpin and "ON" or "OFF")
end)

introBtn.MouseButton1Click:Connect(function()
	autoIntro = not autoIntro
	introBtn.Text = "Skip Intro: " .. (autoIntro and "ON" or "OFF")
end)

--// GET LEVEL
local function getLevel()
	local success, result = pcall(function()
		return player.PlayerGui.StatsGui.BarsFrame.Level.Text
	end)
	return success and result or "?"
end

--// GET SPIN (SERVER FIRST)
local function getSpin()
	local success, result = pcall(function()
		return GetSpinsRemote:InvokeServer()
	end)

	if success and result then
		return tostring(result)
	end

	-- fallback GUI
	local success2, result2 = pcall(function()
		return player.PlayerGui.Spinner.Frame.Spin.TextLabel.Text
	end)

	return success2 and result2 or "?"
end

--// AUTOFARM
task.spawn(function()
	while true do
		if autoFarm then
			local character = player.Character
			local backpack = player:FindFirstChild("Backpack")

			if character and backpack then
				table.clear(moves)

				for _, tool in ipairs(backpack:GetChildren()) do
					if tool:IsA("Tool") then
						table.insert(moves, tool.Name)
					end
				end

				if #moves > 0 then
					for _, move in ipairs(moves) do
						StartMove:FireServer(move)
					end

					task.wait(0.05)

					for _, move in ipairs(moves) do
						EndMove:FireServer(move)
					end
				end
			end
		end
		task.wait(0.15)
	end
end)

--// AUTOSPIN
task.spawn(function()
	while true do
		if autoSpin then
			local levelText = getLevel()
			local level = tonumber(string.match(levelText, "%d+"))
			local spins = tonumber(getSpin())

			if level and level >= 6 and spins and spins > 0 then
				pcall(function()
					SpinRemote:InvokeServer()
				end)

				task.wait(1)

				if player.Character then
					player.Character:BreakJoints()
				end

				task.wait(3)
			end
		end
		task.wait(1)
	end
end)

--// AUTO INTRO
task.spawn(function()
	while true do
		if autoIntro then
			pcall(function()
				IntroRemote:InvokeServer()
			end)
		end
		task.wait(1)
	end
end)

--// UPDATE UI
task.spawn(function()
	while true do
		levelLabel.Text = "Level: " .. getLevel()
		spinLabel.Text = "Spin: " .. getSpin()
		task.wait(0.5)
	end
end)

--// RESPAWN FIX
player.CharacterAdded:Connect(function()
	task.wait(1)
	print("Script vẫn chạy sau respawn")
end)

--// ANTI AFK
player.Idled:Connect(function()
	VirtualUser:CaptureController()
	VirtualUser:ClickButton2(Vector2.new(0,0))
end)

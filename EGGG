--// DATA
local function getLevel()
	local s,r = pcall(function()
		return player.PlayerGui.StatsGui.BarsFrame.Level.Text
	end)
	return s and r or "?"
end

local function getSpin()
	local s,r = pcall(function()
		return GetSpinsRemote:InvokeServer()
	end)
	return s and r and tostring(r) or "?"
end

local function getElement()
	local s,r = pcall(function()
		return GetElementRemote:InvokeServer()
	end)
	return s and r and tostring(r) or "?"
end

--// AUTO ELEMENT
task.spawn(function()
	local lastSpinCount = tonumber(getSpin()) or 0

	while true do
		if autoElement then
			local spins = tonumber(getSpin())

			if spins and spins > 0 then
				SpinRemote:InvokeServer()
				task.wait(0.25)

				local newSpin = tonumber(getSpin())

				if newSpin and newSpin < lastSpinCount then
					local result = getElement()

					local logText = formatElement(result, tostring(newSpin))
					table.insert(spinHistory, logText)

					spinCount += 1
					lastSpinCount = newSpin

					-- 🔥 TAG NGAY KHI RARE
					if highlightElements[result] then
						sendWebhook({ "🌟 RARE: " .. logText }, true)
					end

					if spinCount >= MAX_LOG then
						sendWebhook(spinHistory, false)
						table.clear(spinHistory)
						spinCount = 0
					end

					if selectedElements[result] then
						autoElement = false
						elementBtn.Text = "Auto Element: DONE"
					end
				end
			end
		end
		task.wait(0.3)
	end
end)

--// DATA
local function getLevel()
	local s,r = pcall(function()
		return player.PlayerGui.StatsGui.BarsFrame.Level.Text
	end)
	return s and r or "?"
end

local function getSpin()
	local s,r = pcall(function()
		return GetSpinsRemote:InvokeServer()
	end)
	return s and r and tostring(r) or "?"
end

local function getElement()
	local s,r = pcall(function()
		return GetElementRemote:InvokeServer()
	end)
	return s and r and tostring(r) or "?"
end

--// WEBHOOK SEND
local function sendWebhook(logTable)
	local content = "🎯 **Spin Log (5 lần gần nhất):**\n"

	for i, v in ipairs(logTable) do
		content = content .. i .. ". " .. v .. "\n"
	end

	local data = {
		["content"] = content
	}

	local json = HttpService:JSONEncode(data)

	pcall(function()
		request({
			Url = webhookURL,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = json
		})
	end)
end

--// AUTOFARM
task.spawn(function()
	while true do
		if autoFarm then
			local backpack = player:FindFirstChild("Backpack")
			if backpack then
				table.clear(moves)
				for _,tool in ipairs(backpack:GetChildren()) do
					if tool:IsA("Tool") then
						table.insert(moves, tool.Name)
					end
				end

				for _,m in ipairs(moves) do
					StartMove:FireServer(m)
				end
				task.wait(0.05)
				for _,m in ipairs(moves) do
					EndMove:FireServer(m)
				end
			end
		end
		task.wait(0.15)
	end
end)

--// ⚡ AUTO ELEMENT (MULTI SELECT + LOG)
task.spawn(function()
	while true do
		if autoElement then
			local spins = tonumber(getSpin())

			if spins and spins > 0 then
				SpinRemote:InvokeServer()
				task.wait(0.2)

				local after = getElement()

				-- lưu log
				table.insert(spinHistory, after)

				-- đủ 5 lần gửi webhook
				if #spinHistory >= 5 then
					sendWebhook(spinHistory)
					table.clear(spinHistory)
				end

				-- nếu trúng element đã chọn thì dừng
				if selectedElements[after] then
					autoElement = false
					elementBtn.Text = "Auto Element: DONE"
					print("Đã đạt:", after)
				end
			end
		end
		task.wait(0.1)
	end
end)

--// AUTO SPIN (LEVEL)
task.spawn(function()
	while true do
		if autoSpin then
			local lvl = tonumber(string.match(getLevel(), "%d+"))
			local spins = tonumber(getSpin())

			if lvl and lvl >= 6 and spins and spins > 0 then
				SpinRemote:InvokeServer()
				task.wait(1)
				if player.Character then
					player.Character:BreakJoints()
				end
				task.wait(3)
			end
		end
		task.wait(1)
	end
end)


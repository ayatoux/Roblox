--// SERVICES
local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")

--// REMOTE SPIN
local spin = rs:WaitForChild("Client"):WaitForChild("Spin")

--// GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AyatoHub"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,220,0,200)
frame.Position = UDim2.new(0,20,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Ayato Hub (Drag)"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1

-- DRAG
local dragging, dragInput, dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

title.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

title.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- DISPLAY
local levelUI = Instance.new("TextLabel", frame)
levelUI.Size = UDim2.new(1,0,0,25)
levelUI.Position = UDim2.new(0,0,0,30)
levelUI.Text = "Level: ..."
levelUI.TextColor3 = Color3.new(1,1,1)
levelUI.BackgroundTransparency = 1

local spinUI = Instance.new("TextLabel", frame)
spinUI.Size = UDim2.new(1,0,0,25)
spinUI.Position = UDim2.new(0,0,0,55)
spinUI.Text = "Spins: ..."
spinUI.TextColor3 = Color3.new(1,1,1)
spinUI.BackgroundTransparency = 1

-- BUTTON
local farmBtn = Instance.new("TextButton", frame)
farmBtn.Size = UDim2.new(1,-20,0,40)
farmBtn.Position = UDim2.new(0,10,0,85)
farmBtn.Text = "Auto Farm: OFF"

local spinBtn = Instance.new("TextButton", frame)
spinBtn.Size = UDim2.new(1,-20,0,40)
spinBtn.Position = UDim2.new(0,10,0,135)
spinBtn.Text = "Auto Spin: OFF"

-- SETTINGS
local autoFarm = false
local autoSpin = false
local spinning = false

-- FUNCTIONS
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function getLevel()
    local lvlLabel = player.PlayerGui.StatsGui.BarsFrame.Level
    return tonumber(string.match(lvlLabel.Text, "%d+")) or 1
end

local function getSpinCount()
    local txt = player.PlayerGui.Spinner.Frame.Spin.TextLabel.Text
    return tonumber(string.match(txt, "%d+")) or 0
end

local function resetChar()
    local char = getChar()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = 0
    end
end

-- 🔥 LẤY SKILL CHỈ TỪ BACKPACK (Đã sửa theo yêu cầu)
local function getSkills()
    local skills = {}

    for _, v in pairs(player.Backpack:GetChildren()) do
        if v:IsA("Tool") then
            table.insert(skills, v)
        end
    end

    return skills
end

-- BUTTON
farmBtn.MouseButton1Click:Connect(function()
    autoFarm = not autoFarm
    farmBtn.Text = "Auto Farm: " .. (autoFarm and "ON" or "OFF")
end)

spinBtn.MouseButton1Click:Connect(function()
    autoSpin = not autoSpin
    spinBtn.Text = "Auto Spin: " .. (autoSpin and "ON" or "OFF")
end)

-- UPDATE UI
task.spawn(function()
    while true do
        levelUI.Text = "Level: " .. getLevel()
        spinUI.Text = "Spins: " .. getSpinCount()
        task.wait(0.5)
    end
end)

-- AUTO FARM (dùng skill hiện có)
task.spawn(function()
    while true do
        if autoFarm and not spinning then
            local char = getChar()
            local root = char:WaitForChild("HumanoidRootPart")
            local base = workspace:WaitForChild("Base")

            root.CFrame = base.CFrame + Vector3.new(0,3,0)

            local skills = getSkills()

            for _, tool in ipairs(skills) do
                char.Humanoid:EquipTool(tool)
                task.wait(0.1)

                pcall(function()
                    tool:Activate()
                end)

                task.wait(0.2)
            end
        end
        task.wait(0.3)
    end
end)

-- AUTO SPIN LOOP
task.spawn(function()
    while true do
        if autoSpin and not spinning then
            if getLevel() >= 5 then
                spinning = true

                spin:InvokeServer()
                task.wait(1)

                resetChar()
                task.wait(3)

                spinning = false
            end
        end
        task.wait(1)
    end
end)

--// FORMAT
local function formatElement(element, spinsLeft)
	if highlightElements[element] then
		return "🌟 **" .. element .. "** | Spin left: " .. spinsLeft
	else
		return element .. " | Spin left: " .. spinsLeft
	end
end

--// WEBHOOK
local function sendWebhook(logTable, ping)
	local content = ""

	if ping then
		content = "<@" .. userId .. ">\n"
	end

	content = content .. "🎯 **Spin Log:**\n"

	for i, v in ipairs(logTable) do
		content = content .. i .. ". " .. v .. "\n"
	end

	local data = {["content"] = content}
	local json = HttpService:JSONEncode(data)

	pcall(function()
		request({
			Url = webhookURL,
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = json
		})
	end)
end


--// SERVICES
local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")

--// REMOTES
local moveFolder = rs:WaitForChild("864144468Client")
local startMove = moveFolder:WaitForChild("StartMove")
local endMove = moveFolder:WaitForChild("EndMove")

local clientFolder = rs:WaitForChild("Client")
local spin = clientFolder:WaitForChild("Spin")
local spinCooldown = clientFolder:WaitForChild("SpinCooldown")
local intro = clientFolder:WaitForChild("Intro")

--// GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AyatoHub"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,150)
frame.Position = UDim2.new(0,20,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "Ayato Hub"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1

local farmBtn = Instance.new("TextButton", frame)
farmBtn.Size = UDim2.new(1,-20,0,40)
farmBtn.Position = UDim2.new(0,10,0,40)
farmBtn.Text = "Auto Farm: OFF"

local spinBtn = Instance.new("TextButton", frame)
spinBtn.Size = UDim2.new(1,-20,0,40)
spinBtn.Position = UDim2.new(0,10,0,90)
spinBtn.Text = "Auto Spin: OFF"

--// SETTINGS
local autoFarm = false
local autoSpin = false
local lastLevel = 0
local spinning = false

-- skill
local skills = {
    "Demonstration",
    "Rocket Blast",
    "Soaring Rocket",
    "Firework Traversal",
    "Recursive Fireworks"
}

--// FUNCTIONS
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function getLevel()
    local levelLabel = player:WaitForChild("PlayerGui")
        :WaitForChild("StatsGui")
        :WaitForChild("BarsFrame")
        :WaitForChild("Level")

    local text = levelLabel.Text
    return tonumber(string.match(text, "%d+")) or 1
end

local function resetChar()
    local char = getChar()
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = 0
    end
end

--// BUTTON
farmBtn.MouseButton1Click:Connect(function()
    autoFarm = not autoFarm
    farmBtn.Text = "Auto Farm: " .. (autoFarm and "ON" or "OFF")
end)

spinBtn.MouseButton1Click:Connect(function()
    autoSpin = not autoSpin
    spinBtn.Text = "Auto Spin: " .. (autoSpin and "ON" or "OFF")
end)

--// AUTO FARM
task.spawn(function()
    while true do
        if autoFarm and not spinning then
            local char = getChar()
            local root = char:WaitForChild("HumanoidRootPart")
            local base = workspace:WaitForChild("Base")

            root.CFrame = base.CFrame + Vector3.new(0,3,0)

            for _, skill in ipairs(skills) do
                startMove:FireServer(skill)
                task.wait(0.1)
                endMove:FireServer(skill)
            end
        end
        task.wait(0.3)
    end
end)

--// AUTO SPIN (RESET TRƯỚC & SAU)
task.spawn(function()
    while true do
        if autoSpin and not spinning then
            local lvl = getLevel()

            if lvl >= 30 and lvl ~= lastLevel then
                lastLevel = lvl
                spinning = true

                print("Chuẩn bị spin tại level:", lvl)

                -- reset trước
                resetChar()
                task.wait(3)

                -- đợi spawn
                getChar()
                task.wait(2)

                -- skip intro
                pcall(function()
                    intro:InvokeServer()
                end)

                -- spin 1 lần
                pcall(function()
                    spinCooldown:InvokeServer()
                    spin:InvokeServer()
                end)

                task.wait(2)

                -- reset sau khi spin
                resetChar()
                task.wait(3)

                spinning = false
            end
        end
        task.wait(1)
    end
end)

--// AUTO SKIP INTRO (luôn luôn)
task.spawn(function()
    while true do
        pcall(function()
            intro:InvokeServer()
        end)
        task.wait(2)
    end
end)

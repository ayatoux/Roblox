--// GET DATA
local function getSpin()
	local s,r = pcall(function()
		return GetSpinsRemote:InvokeServer()
	end)
	return s and tonumber(r) or 0
end

local function getElement()
	local s,r = pcall(function()
		return GetElementRemote:InvokeServer()
	end)
	return s and tostring(r) or "?"
end

--// DISCORD EMBED
local function sendEmbed(el, spins)
	local rarity = rarityTable[el]
	if not rarity then return end

	local data = {
		content = rarity == "Myth" and ("<@"..USER_ID.."> 🔥 MYTH!") or nil,
		embeds = {{
			title = "Element Roll",
			description = "**"..el.."**",
			color = colors[rarity],
			fields = {
				{name="Rarity",value=rarity,inline=true},
				{name="Spins",value=tostring(spins),inline=true},
				{name="Player",value=player.Name}
			}
		}}
	}

	request({
		Url = WEBHOOK_URL,
		Method = "POST",
		Headers = {["Content-Type"]="application/json"},
		Body = HttpService:JSONEncode(data)
	})
end

--// AUTOFARM
task.spawn(function()
	while true do
		if autoFarm then
			local backpack = player:FindFirstChild("Backpack")
			if backpack then
				table.clear(moves)
				for _,t in ipairs(backpack:GetChildren()) do
					if t:IsA("Tool") then
						table.insert(moves,t.Name)
					end
				end
				for _,m in ipairs(moves) do StartMove:FireServer(m) end
				task.wait(0.05)
				for _,m in ipairs(moves) do EndMove:FireServer(m) end
			end
		end
		task.wait(0.15)
	end
end)

--// AUTO ELEMENT
task.spawn(function()
	while true do
		if autoElement then
			local spins = getSpin()
			if spins > 0 then
				local el = getElement()

				if not selectedElements[el] then
					SpinRemote:InvokeServer()
					task.wait(0.15)
				else
					sendEmbed(el, spins)
					print("Đạt:", el)
					autoElement = false
				end
			end
		end
		task.wait(0.1)
	end
end)

--// AUTO SPIN LEVEL
